<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.apiiungo.mapper.BlogMapper">

    <resultMap id="BlogResult" type="com.apiiungo.entity.Blog">
        <id property="id" column="id"/>
        <result property="userId" column="user_id"/>
        <result property="title" column="title"/>
        <result property="content" column="content"/>
        <result property="tags" column="tags"/>
        <result property="status" column="status"/>
        <result property="top" column="top"/>
        <result property="openScope" column="open_scope"/>
        <result property="createTime" column="create_time"/>
        <result property="updateTime" column="update_time"/>
        <result property="read" column="read"/>
    </resultMap>

    <insert id="insertBlog" parameterType="com.apiiungo.entity.Blog" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO blog (user_id, title, content, tags, status, top, open_scope, create_time, update_time, `read`)
        VALUES (#{userId}, #{title}, #{content}, #{tags},
                #{status, jdbcType=TINYINT}, #{top, jdbcType=TINYINT}, #{openScope, jdbcType=TINYINT},
                #{createTime}, #{updateTime}, #{read})
    </insert>

    <update id="updateBlog" parameterType="com.apiiungo.entity.Blog">
        UPDATE blog
        SET title = #{title},
            content = #{content},
            tags = #{tags},
            status = #{status},
            top = #{top},
            open_scope = #{openScope},
            update_time = #{updateTime},
            `read` = #{read}
        WHERE id = #{id}
    </update>

    <select id="selectById" parameterType="long" resultMap="BlogResult">
        SELECT *
        FROM blog
        WHERE id = #{id}
    </select>

    <select id="selectByUser" parameterType="long" resultMap="BlogResult">
        SELECT *
        FROM blog
        WHERE user_id = #{userId}
        ORDER BY create_time DESC
    </select>

    <select id="selectPublic" resultMap="BlogResult">
        SELECT *
        FROM blog
        WHERE status = 1
          AND open_scope = 2
        ORDER BY create_time DESC
    </select>

    <!-- 查询所有已使用的标签，按逗号拆分并去重。
         简单实现：直接返回去重后的 tags 字符串，前端可再拆分。 -->
    <select id="selectAllTags" resultType="java.lang.String">
        SELECT DISTINCT tags
        FROM blog
        WHERE tags IS NOT NULL
          AND tags &lt;> ''
    </select>

    <select id="selectAll" resultMap="BlogResult">
        SELECT *
        FROM blog
        ORDER BY create_time DESC
    </select>

    <delete id="deleteById" parameterType="long">
        DELETE FROM blog WHERE id = #{id}
    </delete>

</mapper>

